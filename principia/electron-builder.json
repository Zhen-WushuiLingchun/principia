{
  "appId": "com.principia.app",
  "productName": "Principia",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "electron/**/*",
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "electron/app.exe",
      "to": "app.exe"
    },
    {
      "from": "electron/app",
      "to": "app"
    },
    {
      "from": "electron/app",
      "to": "app"
    }
  ],
  "win": {
    "target": ["nsis", "portable"],
    "icon": "public/favicon.png",
    "arch": ["x64", "ia32", "arm64"]
  },
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "public/favicon.png",
    "category": "public.app-category.utilities",
    "arch": ["x64", "arm64"]
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "public/favicon.png",
    "category": "Utility",
    "arch": ["x64", "arm64"]
  }
}
