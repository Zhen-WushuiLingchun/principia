{
  "name": "the-principia",
  "private": true,
  "version": "1.3.0",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n \"VITE,BACKEND\" -c \"cyan.bold,green.bold\" \"vite\" \"node scripts/start-backend.js\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "install-deps": "npm install",
    "start": "npm run dev",
    "build-frontend": "npm run build",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.principia.app",
    "productName": "Principia",
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "electron/app.exe",
        "to": "app.exe"
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/favicon.png"
    }
  },
  "dependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/jspdf": "^1.3.3",
    "@types/jszip": "^3.4.0",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.23.26",
    "jspdf": "^3.0.4",
    "jszip": "^3.10.1",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.0.11",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
